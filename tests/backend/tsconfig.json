{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["jest", "node"],
    "typeRoots": [
      "../../backend/node_modules/@types",
      "../../frontend/node_modules/@types"
    ],
    "baseUrl": "../../backend",
    "paths": {}
  },
  "include": [
    "./**/*.ts",
    "../../backend/**/*.ts"
  ]
}
